{
  "name": "par-lint-cli",
  "version": "0.2.0",
  "description": "Experimental deterministic linter for AI agents — studying structured code validation as input for LLM assistants",
  "type": "module",
  "bin": {
    "par-lint": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "par-lint": "node ./dist/cli/index.js"
  },
  "author": "Renzo Oliveira",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "lint",
    "angular",
    "ionic",
    "typescript",
    "scss",
    "code-quality",
    "ai-agents",
    "claude-code",
    "deterministic",
    "architecture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/renzooliveira/par-lint-cli.git"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "globby": "^16.2.0",
    "ora": "^9.4.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ast-grep/napi": "^0.42.1",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
